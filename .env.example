# Groq API
GROQ_API_KEY=your_groq_api_key_here

# Email Configuration (for sending PDF via email)
# For Gmail users:
# 1. Enable 2-factor authentication
# 2. Generate App Password at: https://myaccount.google.com/apppasswords
# 3. Use the app password below (not your regular password)

SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_app_password_here

# SMTP Server Configuration (Gmail defaults)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# For other email providers, use:
# Outlook: smtp-mail.outlook.com (port 587)
# Yahoo: smtp.mail.yahoo.com (port 587)
# Other: contact your email provider
